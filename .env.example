# Copy to `.env` or `.env.local` and fill in values.

# Postgres for Prisma (Supabase → Settings → Database → connection string)
# IMPORTANT for serverless/Vercel: use the TRANSACTION POOLER URL (pgBouncer),
# host "...pooler.supabase.com", port 6543 — it multiplexes many client
# connections onto a few backends so you don't hit Supabase's ~15-connection
# cap. The app's pool (src/lib/pg-pool.ts) auto-detects this and sizes itself.
#   Pooler:  postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Direct:  postgresql://postgres:<pwd>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL="postgresql://..."
# Optional: override the per-instance pool size (defaults: local 10, pooler 6, direct 2)
# DB_POOL_MAX="6"

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Prefer the Publishable key from the dashboard; legacy anon JWT still works if set instead:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."  # optional legacy fallback

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: http://localhost:3000 (or your deployed origin)
# - Redirect URLs: include http://localhost:3000/auth/callback

# OpenAI (server-only): Agents SDK + Meme agent image generation (/api/agents/meme)
OPENAI_API_KEY="sk-..."

# LLM models (optional overrides; defaults are GPT-5.5 everywhere)
# AI_MODEL="openai/gpt-5.5"          # Vercel AI gateway — orchestrator routing + general agent
# AI_AGENT_MODEL="gpt-5.5"           # OpenAI Agents SDK — food, grooming, vet, booking, meme

# OneMap (server-only, optional): precise Singapore postal-code geocoding for discovery.
# Use either a short-lived token, or credentials so the app can request/cache one.
# ONEMAP_API_TOKEN="..."
# ONEMAP_EMAIL="you@example.com"
# ONEMAP_PASSWORD="..."

# Image storage — Supabase Storage via the S3 protocol (server-only).
# Supabase Dashboard → Storage → S3 connection. Bucket "media" is PRIVATE; the
# app stores object keys and serves short-lived signed URLs.
S3_ENDPOINT="https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY_ID="..."
S3_SECRET_ACCESS_KEY="..."
S3_BUCKET="media"
