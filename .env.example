# Copy to `.env` or `.env.local` and fill in values.

# Postgres for Prisma (Supabase → Settings → Database → connection string)
DATABASE_URL="postgresql://..."

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Prefer the Publishable key from the dashboard; legacy anon JWT still works if set instead:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."  # optional legacy fallback

# Supabase Dashboard → Authentication → URL configuration:
# - Site URL: http://localhost:3000 (or your deployed origin)
# - Redirect URLs: include http://localhost:3000/auth/callback

# OpenAI (server-only): Agents SDK + Meme agent image generation (/api/agents/meme)
OPENAI_API_KEY="sk-..."
