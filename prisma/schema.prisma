// Prisma schema — app data stored in your Postgres (often the same DB as Supabase).
// Pet.userId matches auth.users.id from Supabase.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Pet {
  id        String   @id @default(cuid())
  userId    String
  name      String
  species   String
  breed     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
